{
  "index_patterns": ["workflow-events-*"],
  "template": {
    "settings": {
      "index.lifecycle.name": "data-index-events-retention",
      "number_of_shards": 3,
      "number_of_replicas": 1
    },
    "mappings": {
      "properties": {
        "@timestamp": {
          "type": "date",
          "doc_values": true
        },
        "tag": {
          "type": "keyword"
        },
        "event_id": {
          "type": "keyword"
        },
        "event_type": {
          "type": "keyword"
        },
        "event_time": {
          "type": "date"
        },
        "instance_id": {
          "type": "keyword"
        },
        "workflow_name": {
          "type": "keyword"
        },
        "workflow_version": {
          "type": "keyword"
        },
        "workflow_namespace": {
          "type": "keyword"
        },
        "status": {
          "type": "keyword"
        },
        "start": {
          "type": "date"
        },
        "end": {
          "type": "date"
        },
        "input": {
          "type": "flattened"
        },
        "output": {
          "type": "flattened"
        },
        "error": {
          "properties": {
            "type": {
              "type": "keyword"
            },
            "title": {
              "type": "text"
            },
            "detail": {
              "type": "text"
            },
            "status": {
              "type": "integer"
            },
            "instance": {
              "type": "keyword"
            }
          }
        }
      }
    }
  }
}
